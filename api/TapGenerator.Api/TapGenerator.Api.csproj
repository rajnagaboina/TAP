<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>TapGenerator.Api</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- Entra JWT validation -->
    <PackageReference Include="Microsoft.Identity.Web" Version="3.3.1" />
    <!-- Azure SDK – Managed Identity / DefaultAzureCredential -->
    <PackageReference Include="Azure.Identity" Version="1.13.1" />
    <!-- Microsoft Graph SDK v5 -->
    <PackageReference Include="Microsoft.Graph" Version="5.65.0" />
    <!-- Structured logging to App Insights -->
    <PackageReference Include="Microsoft.ApplicationInsights.AspNetCore" Version="2.22.0" />
    <!-- OpenAPI / Swagger UI -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.10" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.9.0" />
  </ItemGroup>

</Project>
