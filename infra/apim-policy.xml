<!--
  APIM Inbound Policy – TAP Generator API
  Apply this at the API level (not product/global level).

  Before applying, replace every {{PLACEHOLDER}} with real values
  from your azure-config.yaml, or set APIM Named Values for them:
    tenant-id      → entra.tenantId
    api-client-id  → entra.apiAppRegistration.clientId
    ui-origin      → https://<uiAppService.name>.azurewebsites.net
    api-backend    → https://<apiAppService.name>.azurewebsites.net
-->
<policies>
  <inbound>
    <base />

    <!-- 1. Validate JWT issued by Entra, check TAP.Generator role -->
    <validate-jwt
        header-name="Authorization"
        failed-validation-httpcode="401"
        failed-validation-error-message="Unauthorized: valid Bearer token with TAP.Generator role required."
        require-expiration-time="true"
        require-signed-tokens="true">
      <openid-config url="https://login.microsoftonline.com/ac1cd4e7-b14c-42dd-aac0-7543da3fb35f/v2.0/.well-known/openid-configuration" />
      <audiences>
        <audience>api://6b1a0438-1405-45dc-a09c-d3282d41e37c</audience>
      </audiences>
      <issuers>
        <issuer>https://login.microsoftonline.com/ac1cd4e7-b14c-42dd-aac0-7543da3fb35f/v2.0</issuer>
        <issuer>https://sts.windows.net/ac1cd4e7-b14c-42dd-aac0-7543da3fb35f/</issuer>
      </issuers>
      <required-claims>
        <claim name="roles" match="any" separator=" ">
          <value>TAP.Generator</value>
        </claim>
      </required-claims>
    </validate-jwt>

    <!-- 2. CORS – allow only the UI origin -->
    <cors allow-credentials="true">
      <allowed-origins>
        <origin>https://tap-gvfqfhc9g5chceg4.westus2-01.azurewebsites.net</origin>
      </allowed-origins>
      <allowed-methods preflight-result-max-age="300">
        <method>POST</method>
        <method>OPTIONS</method>
      </allowed-methods>
      <allowed-headers>
        <header>Authorization</header>
        <header>Content-Type</header>
        <header>X-Request-Id</header>
      </allowed-headers>
      <expose-headers>
        <header>X-Request-Id</header>
      </expose-headers>
    </cors>

    <!-- 3. Route to the API App Service backend -->
    <set-backend-service base-url="https://asp-tap-generator-api.azurewebsites.net" />

    <!-- 4. Inject correlation ID for end-to-end tracing -->
    <set-header name="X-Request-Id" exists-action="skip">
      <value>@(Guid.NewGuid().ToString())</value>
    </set-header>

    <!-- 5. Strip Authorization from backend call if using MI-to-MI;
         Remove this line if the .NET API also validates the Bearer token -->
    <!-- <set-header name="Authorization" exists-action="delete" /> -->

  </inbound>

  <backend>
    <base />
  </backend>

  <outbound>
    <base />
    <!-- Remove server identity headers -->
    <set-header name="X-Powered-By" exists-action="delete" />
    <set-header name="X-AspNet-Version" exists-action="delete" />
    <set-header name="Server" exists-action="delete" />
  </outbound>

  <on-error>
    <base />
    <return-response>
      <set-status code="@((int)context.LastError.StatusCode)" reason="@(context.LastError.Reason)" />
      <set-header name="Content-Type" exists-action="override">
        <value>application/json</value>
      </set-header>
      <set-body>@($"{{\"error\": \"{context.LastError.Message}\"}}")</set-body>
    </return-response>
  </on-error>
</policies>
